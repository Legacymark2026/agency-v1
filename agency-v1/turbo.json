{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "POSTGRES_EXTERNAL_URL",
    "META_APP_ID",
    "META_APP_SECRET",
    "META_ACCESS_TOKEN",
    "FACEBOOK_CAPI_TOKEN",
    "GA_API_SECRET",
    "GA_PRIVATE_KEY",
    "TIKTOK_ACCESS_TOKEN",
    "BLOB_READ_WRITE_TOKEN",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*", ".env.local", ".env.production"],
      "outputs": [".next/**/*", "!.next/cache/**/*", "dist/**/*", "build/**/*"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    }
  }
}
