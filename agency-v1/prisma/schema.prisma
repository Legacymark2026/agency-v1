// ── Módulo Agente Cognitivo: Historial de Conversaciones ────────────────────
model AgentConversation {
  id              String    @id @default(uuid())
  title           String    @default("Nueva conversación")
  userId          String?   @map("user_id") // Human agent assigned
  companyId       String    @map("company_id")
  agentId         String?   @map("agent_id") // Linked specialized agent
  contactId       String?   @map("contact_id")
  status          String    @default("ACTIVE") // ACTIVE | SUSPENDED | CLOSED
  suspendedUntil  DateTime? @map("suspended_until")
  suspendedReason String?   @map("suspended_reason") // HUMAN_OVERRIDE | FRUSTRATION | MANUAL
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  messages AgentMessage[]
  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent    AIAgent?       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([agentId, status])
  @@map("agent_conversations")
}

model AgentMessage {
  id              String   @id @default(uuid())
  conversationId  String   @map("conversation_id")
  role            String // user | assistant | human_agent | system
  content         String   @db.Text
  rawContent      String?  @map("raw_content") @db.Text // Pre-style-filter
  sentimentScore  Float?   @map("sentiment_score") // 0.0-1.0 frustration
  isHumanOverride Boolean  @default(false) @map("is_human_override")
  tokensUsed      Int?     @map("tokens_used")
  latencyMs       Int?     @map("latency_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  conversation AgentConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@map("agent_messages")
}

model AgentConfig {
  id        String  @id @default(uuid())
  companyId String  @unique @map("company_id")
  isActive  Boolean @default(true) @map("is_active")

  // LLM Settings
  systemPrompt String? @map("system_prompt") @db.Text
  llmModel     String  @default("gemini-2.0-flash-lite") @map("llm_model")
  temperature  Float   @default(0.7)
  maxTokens    Int     @default(1024) @map("max_tokens")

  // Custom Variables para el Agente
  adminWhatsappPhone String? @map("admin_whatsapp_phone")
  monthlySalesTarget Float?  @map("monthly_sales_target")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

// ── Módulo Agente Cognitivo: Agentes Especializados (Multi-Agent Hub) ────────
model AIAgent {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  name        String
  description String? @db.Text
  agentType   String  @default("CUSTOM") @map("agent_type") // SUPPORT | SALES | CUSTOM
  isActive    Boolean @default(true) @map("is_active")
  isInboxAgent Boolean @default(false) @map("is_inbox_agent")

  // LLM Settings
  systemPrompt String @map("system_prompt") @db.Text
  llmModel     String @default("gemini-2.0-flash") @map("llm_model")
  temperature  Float  @default(0.4)
  maxTokens    Int    @default(400) @map("max_tokens")

  // Tools configuration
  enabledTools Json @default("[]") @map("enabled_tools")

  // RAG — Knowledge Base
  knowledgeBases KnowledgeBase[]
  strictRagMode  Boolean         @default(false) @map("strict_rag_mode")

  // Human-in-the-Loop
  humanTransferWebhook      String? @map("human_transfer_webhook")
  suspensionDurationMinutes Int     @default(30) @map("suspension_duration_minutes")
  priorityAlpha             Boolean @default(true) @map("priority_alpha")
  frustrationThreshold      Float   @default(0.8) @map("frustration_threshold")

  // Guardrails
  enforceTempClamp  Boolean @default(false) @map("enforce_temp_clamp")
  enforceTokenLimit Boolean @default(true) @map("enforce_token_limit")

  // Human Mimicry
  simulateLatency    Boolean @default(true) @map("simulate_latency")
  filterRoboticLists Boolean @default(true) @map("filter_robotic_lists")

  // Voice & Persona Settings
  voiceId         String? @map("voice_id")
  stability       Float   @default(0.5)
  similarityBoost Float   @default(0.75) @map("similarity_boost")
  accentRegion    String? @map("accent_region") // e.g., "es-CO", "es-ES", "es-MX"
  gender          String? // "MALE", "FEMALE", "NEUTRAL"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  conversations AgentConversation[]

  @@index([companyId])
  @@index([isActive])
  @@index([companyId, isActive])
  @@map("ai_agents")
}

// --- FASE 5: ERP EMPRESARIAL (PROJECT MANAGEMENT) ---

model KanbanProject {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  status      String    @default("ACTIVE") // ACTIVE, ON_HOLD, COMPLETED, CANCELLED
  companyId   String    @map("company_id")
  dealId      String?   @unique @map("deal_id") // One-to-one con Deal ganado
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  budget      Float?
  spentAmount Float     @default(0) @map("spent_amount")
  healthScore Int       @default(100) @map("health_score") // 0 to 100
  isPublic    Boolean   @default(false) @map("is_public")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal        Deal?              @relation(fields: [dealId], references: [id])
  kanbanTasks KanbanTask[]
  swimlanes   KanbanSwimlane[]
  healthLogs  ProjectHealthLog[]

  @@index([companyId])
  @@index([status])
  @@map("kanban_projects")
}

model KanbanSwimlane {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  name      String
  order     Int      @default(0)
  wipLimit  Int?     @map("wip_limit")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project     KanbanProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kanbanTasks KanbanTask[]

  @@index([projectId])
  @@map("kanban_swimlanes")
}

model ProjectHealthLog {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  timestamp   DateTime @default(now())
  healthScore Int // 0 to 100
  notes       String?  @db.Text

  project KanbanProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_health_logs")
}

model KanbanTask {
  id             String    @id @default(uuid())
  title          String
  description    String?   @db.Text
  status         String    @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE, ARCHIVED
  priority       String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  order          Int       @default(0)
  projectId      String    @map("project_id")
  assigneeId     String?   @map("assignee_id")
  creatorId      String    @map("creator_id")
  dueDate        DateTime? @map("due_date")
  estimatedHours Float?    @map("estimated_hours")
  swimlaneId     String?   @map("swimlane_id")
  labels         Json      @default("[]") // string[]
  storyPoints    Int?      @map("story_points")
  mediaUrls      Json      @default("[]") @map("media_urls") // {url,version}[]
  // ── Enterprise fields ──────────────────────────────────────────────────────
  costPerHour    Float?    @map("cost_per_hour") // Override de tarifa del empleado
  budgetCap      Float?    @map("budget_cap") // Presupuesto asignado a esta tarea
  slaDeadline    DateTime? @map("sla_deadline") // SLA personalizado (alerta si se incumple)
  archived       Boolean   @default(false) // Soft-delete para historial
  archivedAt     DateTime? @map("archived_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project     KanbanProject           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  swimlane    KanbanSwimlane?         @relation(fields: [swimlaneId], references: [id])
  assignee    User?                   @relation("KanbanTaskAssignee", fields: [assigneeId], references: [id])
  creator     User                    @relation("KanbanTaskCreator", fields: [creatorId], references: [id])
  timeEntries TimeEntry[]
  comments    KanbanComment[]
  subtasks    KanbanSubtask[]
  auditLogs   KanbanAuditLog[]
  annotations KanbanAssetAnnotation[]
  deal        Deal?

  @@index([projectId])
  @@index([swimlaneId])
  @@index([assigneeId])
  @@index([status])
  @@map("kanban_tasks")
}

model KanbanComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  content   String   @db.Text
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  task   KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User       @relation("KanbanCommentAuthor", fields: [authorId], references: [id])

  @@index([taskId])
  @@map("kanban_comments")
}

model KanbanSubtask {
  id           String   @id @default(uuid())
  parentTaskId String   @map("parent_task_id")
  title        String
  completed    Boolean  @default(false)
  isBlocking   Boolean  @default(false) @map("is_blocking")
  order        Int      @default(0)
  creatorId    String   @map("creator_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  parentTask KanbanTask @relation(fields: [parentTaskId], references: [id], onDelete: Cascade)
  creator    User       @relation("KanbanSubtaskCreator", fields: [creatorId], references: [id])

  @@index([parentTaskId])
  @@map("kanban_subtasks")
}

// --- KANBAN ENTERPRISE: Audit, Templates, Proofing ---

model KanbanAuditLog {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  actorId   String   @map("actor_id")
  action    String // STATUS_CHANGE, PRIORITY_CHANGE, ASSIGNEE_CHANGE, POSITION_CHANGE, etc
  fromValue String?  @map("from_value") @db.Text
  toValue   String?  @map("to_value") @db.Text
  metadata  Json? // additional context
  createdAt DateTime @default(now()) @map("created_at")

  task  KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User       @relation("KanbanAuditActor", fields: [actorId], references: [id])

  @@index([taskId])
  @@index([actorId])
  @@map("kanban_audit_logs")
}

model KanbanProjectTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?  @db.Text
  icon        String?  @default("📋")
  companyId   String?  @map("company_id") // null = global template
  structure   Json // { swimlanes: [{name, tasks: [{title, priority, labels, estimatedHours}]}] }
  isGlobal    Boolean  @default(false) @map("is_global")
  usageCount  Int      @default(0) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([companyId])
  @@map("kanban_project_templates")
}

model KanbanAssetAnnotation {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  assetUrl  String   @map("asset_url") @db.Text
  xPercent  Float    @map("x_percent") // 0-100 percentage of image width
  yPercent  Float    @map("y_percent") // 0-100 percentage of image height
  timestamp Float? // for video — seconds from start
  comment   String   @db.Text
  resolved  Boolean  @default(false)
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")

  task   KanbanTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User       @relation("AnnotationAuthor", fields: [authorId], references: [id])

  @@index([taskId])
  @@map("kanban_asset_annotations")
}

// --- FASE 5: SPRINT 2 - COTIZADORES Y FIRMAS DIGITALES ---

model Proposal {
  id           String    @id @default(uuid())
  title        String
  content      String?   @db.Text
  status       String    @default("DRAFT") // DRAFT, SENT, VIEWED, SIGNED, REJECTED
  value        Float     @default(0)
  currency     String    @default("USD")
  companyId    String    @map("company_id")
  dealId       String?   @map("deal_id")
  creatorId    String    @map("creator_id")
  contactName  String?   @map("contact_name")
  contactEmail String?   @map("contact_email")
  expiresAt    DateTime? @map("expires_at")
  signedAt     DateTime? @map("signed_at")
  signature    String?   @db.Text
  clientIp     String?   @map("client_ip")
  token        String    @unique @default(uuid())
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal    Deal?          @relation(fields: [dealId], references: [id])
  creator User           @relation(fields: [creatorId], references: [id])
  items   ProposalItem[]

  @@index([companyId])
  @@index([status])
  @@index([token])
  @@map("proposals")
}

model ProposalItem {
  id          String   @id @default(uuid())
  proposalId  String   @map("proposal_id")
  title       String
  description String?  @db.Text
  quantity    Int      @default(1)
  price       Float    @default(0)
  taxRate     Float    @default(0) @map("tax_rate")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@map("proposal_items")
}

model InboxMacro {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  title       String
  description String?
  icon        String?  @default("Wand2")
  color       String   @default("#10b981")
  actionType  String   @default("TEXT_REPLY") // TEXT_REPLY, ASSIGN_TAG, ESCALATE, SEND_PAYMENT_LINK, WEBHOOK
  payload     Json?    @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([actionType])
  @@index([isActive])
  @@map("inbox_macros")
}

model TimeEntry {
  id           String    @id @default(uuid())
  kanbanTaskId String    @map("kanban_task_id")
  userId       String    @map("user_id")
  description  String?
  duration     Int // Duración en segundos
  startedAt    DateTime  @default(now()) @map("started_at")
  endedAt      DateTime? @map("ended_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  kanbanTask  KanbanTask @relation(fields: [kanbanTaskId], references: [id], onDelete: Cascade)
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  timesheet   Timesheet? @relation(fields: [timesheetId], references: [id])
  timesheetId String?    @map("timesheet_id")

  @@index([timesheetId])
  @@index([kanbanTaskId])
  @@index([userId])
  @@map("time_entries")
}

// --- FASE 6: NÓMINA Y EGRESOS DE PERSONAL (DIAN) ---

model Employee {
  id             String    @id @default(uuid())
  companyId      String    @map("company_id")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  documentType   String    @default("CC") @map("document_type") // CC, NIT, CE, PPT
  documentNumber String    @map("document_number")
  email          String?
  phone          String?
  contractType   String    @map("contract_type") // LABORAL, PRESTACION_SERVICIOS
  position       String
  department     String?
  baseSalary     Float     @map("base_salary")
  ptoDays        Int       @default(15) @map("pto_days")
  joiningDate    DateTime? @map("joining_date") @db.Date
  isActive       Boolean   @default(true) @map("is_active")

  // Información Bancaria
  bankName        String? @map("bank_name")
  bankAccount     String? @map("bank_account")
  bankAccountType String? @default("AHORROS") @map("bank_account_type") // AHORROS, CORRIENTE

  // Seguridad Social
  epsName         String? @map("eps_name")
  epsNumber       String? @map("eps_number")
  afpName         String? @map("afp_name") // Fondo de Pensiones
  afpNumber       String? @map("afp_number")
  arlName         String? @map("arl_name") // Riesgos Laborales
  compensationBox String? @map("compensation_box") // Caja de Compensación
  riskLevel       Int     @default(1) @map("risk_level") // Nivel de riesgo ARL (1-5)

  // Contacto de Emergencia
  emergencyContactName  String? @map("emergency_contact_name")
  emergencyContactPhone String? @map("emergency_contact_phone")
  emergencyContactRel   String? @map("emergency_contact_rel") // ESPOSO/A, PADRE/MADRE, HIJO/A

  // Datos adicionales
  address   String?   @db.Text
  city      String?
  birthDate DateTime? @map("birth_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payrolls   Payroll[]
  timesheets Timesheet[]
  timeOffs   TimeOffRequest[]
  benefits   EmployeeBenefit[]

  @@unique([companyId, documentNumber])
  @@index([companyId])
  @@index([isActive])
  @@map("employees")
}

model Payroll {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  employeeId  String   @map("employee_id")
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  issueDate   DateTime @default(now()) @map("issue_date")
  status      String   @default("PENDING") // PENDING, PAID, CANCELLED

  // Totales calculados
  totalEarnings   Float @default(0) @map("total_earnings")
  totalDeductions Float @default(0) @map("total_deductions")
  netPay          Float @default(0) @map("net_pay")

  // DIAN tracking
  isElectronic  Boolean @default(true) @map("is_electronic")
  dianStatus    String? @map("dian_status") // PENDING, SENT, ACCEPTED, REJECTED
  cune          String? // Código Único de Nómina Electrónica
  paymentMethod String  @default("TRANSFER") @map("payment_method")
  notes         String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee              @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  items       PayrollItem[]
  transaction FinancialTransaction? // El egreso generado al pagar esta nómina
  auditLogs   PayrollAuditLog[]

  @@index([companyId])
  @@index([employeeId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("payrolls")
}

model PayrollItem {
  id          String  @id @default(uuid())
  payrollId   String  @map("payroll_id")
  type        String // EARNING, DEDUCTION
  concept     String // SALARY, TRANSPORT, HEALTH, PENSION, RETEFUENTE, COMMISSION, BONUS, ADVANCE
  description String? @db.Text
  amount      Float
  baseAmount  Float?  @map("base_amount") // Usado para calcular % de salud/pensión si aplica

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
  @@index([type])
  @@map("payroll_items")
}

// --- FASE 7: TESORERÍA Y FINANZAS (TREASURY) ---

model FinancialAccount {
  id          String  @id @default(uuid())
  companyId   String  @map("company_id")
  name        String
  type        String  @default("BANK_ACCOUNT") // BANK_ACCOUNT, CREDIT_CARD, DIGITAL_WALLET, CASH
  currency    String  @default("COP")
  balance     Float   @default(0) // Saldo actual
  isActive    Boolean @default(true) @map("is_active")
  description String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions FinancialTransaction[]
  expenses     Expense[]

  @@index([companyId])
  @@index([isActive])
  @@map("financial_accounts")
}

model FinancialTransaction {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  type        String // INCOME, EXPENSE, TRANSFER
  amount      Float // Positive absolute value
  category    String // PAYROLL, CLIENT_PAYMENT, SOFTWARE, AD_SPEND, OPERATIONS, TAXES, OTHER
  description String?  @db.Text
  date        DateTime @default(now()) @db.Date // Fecha contable
  reference   String? // Número de comprobante o ref de banco

  // Relaciones opcionales para trazabilidad
  invoiceId String? @map("invoice_id")
  payrollId String? @unique @map("payroll_id") // Una nómina genera un egreso específico

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  invoice Invoice?         @relation(fields: [invoiceId], references: [id])
  payroll Payroll?         @relation(fields: [payrollId], references: [id])

  @@index([accountId])
  @@index([type])
  @@index([category])
  @@index([date])
  @@map("financial_transactions")
}

model Timesheet {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  periodStart  DateTime @map("period_start") @db.Date
  periodEnd    DateTime @map("period_end") @db.Date
  status       String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED
  totalHours   Float    @default(0) @map("total_hours")
  notes        String?  @db.Text
  approvedById String?  @map("approved_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy  User?       @relation("TimesheetApprover", fields: [approvedById], references: [id])
  timeEntries TimeEntry[]

  @@index([employeeId])
  @@index([status])
  @@map("timesheets")
}

model TimeOffRequest {
  id           String   @id @default(uuid())
  employeeId   String   @map("employee_id")
  type         String // VACATION, SICK, PERSONAL, MATERNITY
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime @map("end_date") @db.Date
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason       String?  @db.Text
  approvedById String?  @map("approved_by_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedBy User?    @relation("TimeOffApprover", fields: [approvedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@map("time_off_requests")
}

// ── Beneficios Extralegales por Empleado ─────────────────────────────────────
model EmployeeBenefit {
  id          String    @id @default(uuid())
  employeeId  String    @map("employee_id")
  companyId   String    @map("company_id")
  name        String // Ej: "Prima Extralegal", "Bono de Desempeño"
  amount      Float
  frequency   String    @default("MONTHLY") // MONTHLY, ANNUAL, ONE_TIME
  isActive    Boolean   @default(true) @map("is_active")
  description String?   @db.Text
  startDate   DateTime  @default(now()) @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([companyId])
  @@map("employee_benefits")
}

// ── Categorías de Egresos ────────────────────────────────────────────────────
model ExpenseCategory {
  id        String   @id @default(uuid())
  companyId String   @map("company_id")
  name      String // Ej: "Software", "Publicidad", "Viáticos"
  code      String? // Código contable interno
  color     String?  @default("#6366f1") // Para UI
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([companyId, name])
  @@index([companyId])
  @@map("expense_categories")
}

// ── Egresos Operativos (Gastos) ───────────────────────────────────────────────
model Expense {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  categoryId    String?  @map("category_id")
  title         String
  description   String?  @db.Text
  amount        Float
  currency      String   @default("COP")
  date          DateTime @db.Date
  vendor        String? // Proveedor / Beneficiario
  reference     String? // Número de factura / soporte
  receiptUrl    String?  @map("receipt_url") // URL del comprobante
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, PAID
  paymentMethod String?  @default("TRANSFER") @map("payment_method")

  // Trazabilidad financiera
  accountId    String?   @map("account_id") // Cuenta que pagó el gasto
  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")
  paidAt       DateTime? @map("paid_at")
  notes        String?   @db.Text

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category   ExpenseCategory?  @relation(fields: [categoryId], references: [id])
  account    FinancialAccount? @relation(fields: [accountId], references: [id])
  createdBy  User              @relation("ExpenseCreator", fields: [createdById], references: [id])
  approvedBy User?             @relation("ExpenseApprover", fields: [approvedById], references: [id])

  @@index([companyId])
  @@index([categoryId])
  @@index([status])
  @@index([date])
  @@map("expenses")
}

// ── Auditoría de Nómina ───────────────────────────────────────────────────────
model PayrollAuditLog {
  id        String   @id @default(uuid())
  payrollId String   @map("payroll_id")
  userId    String   @map("user_id")
  action    String // GENERATED, PAID, CANCELLED, RECALCULATED, CLONED
  details   Json? // Estado anterior vs nuevo
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  payroll Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  user    User    @relation("PayrollAuditor", fields: [userId], references: [id])

  @@index([payrollId])
  @@index([userId])
  @@map("payroll_audit_logs")
}

// ─── Creative Studio: Collaboration & Versioning ──────────────────────────────

model AssetAnnotation {
  id        String        @id @default(uuid())
  assetId   String        @map("asset_id")
  authorId  String        @map("author_id")
  content   String        @db.Text
  xPercent  Float         @map("x_percent") // 0..100 relative to image width
  yPercent  Float         @map("y_percent") // 0..100 relative to image height
  status    String        @default("OPEN") // OPEN | RESOLVED
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  asset     CampaignAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  author    User          @relation(fields: [authorId], references: [id])

  @@index([assetId])
  @@index([authorId])
  @@map("asset_annotations")
}

model AssetCollection {
  id          String                @id @default(uuid())
  name        String
  description String?
  companyId   String                @map("company_id")
  createdById String                @map("created_by_id")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  company     Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy   User                  @relation(fields: [createdById], references: [id])
  items       AssetCollectionItem[]

  @@index([companyId])
  @@map("asset_collections")
}

model AssetCollectionItem {
  id           String          @id @default(uuid())
  collectionId String          @map("collection_id")
  assetId      String          @map("asset_id")
  order        Int             @default(0)
  addedAt      DateTime        @default(now()) @map("added_at")
  collection   AssetCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  asset        CampaignAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([collectionId, assetId])
  @@index([collectionId])
  @@map("asset_collection_items")
}

model AssetVersion {
  id          String        @id @default(uuid())
  assetId     String        @map("asset_id")
  version     Int
  url         String
  prompt      String?       @db.Text
  changeNote  String?       @map("change_note") @db.Text
  createdById String        @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  asset       CampaignAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy   User          @relation(fields: [createdById], references: [id])

  @@unique([assetId, version])
  @@index([assetId])
  @@map("asset_versions")
}

// ═══════════════════════════════════════════════════════════
// SETTINGS MODULE — Developer, Webhooks, Notifications, Billing
// ═══════════════════════════════════════════════════════════
// NOTE: ApiKey model already exists in DB (api_keys table) from previous migration.
// Keeping existing relation: User { apiKeys ApiKey[] }
// Webhook and other new models follow below.

model Webhook {
  id              String               @id @default(uuid())
  name            String
  url             String
  secret          String // HMAC secret for signature verification
  events          String[]             @default([])
  companyId       String               @map("company_id")
  isActive        Boolean              @default(true) @map("is_active")
  lastDeliveredAt DateTime?            @map("last_delivered_at")
  lastStatusCode  Int?                 @map("last_status_code")
  failureCount    Int                  @default(0) @map("failure_count")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")
  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deliveryLogs    WebhookDeliveryLog[]

  @@index([companyId])
  @@map("webhooks")
}

model WebhookDeliveryLog {
  id           String   @id @default(uuid())
  webhookId    String   @map("webhook_id")
  event        String
  statusCode   Int?     @map("status_code")
  responseBody String?  @map("response_body") @db.Text
  payload      String?  @db.Text
  durationMs   Int?     @map("duration_ms")
  success      Boolean  @default(false)
  deliveredAt  DateTime @default(now()) @map("delivered_at")
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@map("webhook_delivery_logs")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  companyId String   @map("company_id")
  channel   String // EMAIL | WHATSAPP | PUSH | SLACK
  event     String // NEW_LEAD | PAYMENT_RECEIVED | PAYROLL_DUE | etc.
  enabled   Boolean  @default(true)
  digest    String   @default("IMMEDIATE") // IMMEDIATE | DAILY | WEEKLY
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, channel, event])
  @@index([userId, companyId])
  @@map("notification_preferences")
}

model UsageLog {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  metric     String // API_CALLS | LEADS | EMAIL_SENT | AI_TOKENS | STORAGE_MB
  value      Float
  recordedAt DateTime @default(now()) @map("recorded_at")
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, metric])
  @@index([companyId, recordedAt])
  @@map("usage_logs")
}

model IntegrationLog {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  integration String // GOOGLE | META | STRIPE | TWILIO | SLACK | OPENAI | etc.
  status      String // OK | ERROR | DEGRADED | UNCONFIGURED
  latencyMs   Int?     @map("latency_ms")
  message     String?  @db.Text
  checkedAt   DateTime @default(now()) @map("checked_at")
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, integration])
  @@map("integration_logs")
}

// ═══════════════════════════════════════════════════════════════════
// AI AGENT ORCHESTRATION — Ultra-Pro Module
// ═══════════════════════════════════════════════════════════════════

model KnowledgeBase {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  name        String
  description String?   @db.Text
  sourceType  String    @default("TEXT") @map("source_type") // TEXT | PDF | URL | AUDIO | VIDEO
  sourceUrl   String?   @map("source_url")
  mimeType    String?   @map("mime_type")
  fileUri     String?   @map("file_uri") // Gemini File API URI u otro storage
  content     String    @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents      AIAgent[]

  @@index([companyId])
  @@map("knowledge_bases")
}

// ═══════════════════════════════════════════════════════════════════
// NOTIFICATION ENGINE — Ultra-Pro Module
// ═══════════════════════════════════════════════════════════════════

model Notification {
  id        String    @id @default(uuid())
  companyId String    @map("company_id")
  userId    String    @map("user_id")
  type      String // Ej: NEW_LEAD, TASK_ASSIGNED, MENTION
  title     String
  message   String    @db.Text
  link      String? // Ej: /dashboard/crm/deals/123
  isRead    Boolean   @default(false) @map("is_read")
  metadata  Json?     @default("{}")
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  company                 Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  NotificationDeliveryLog NotificationDeliveryLog[]

  @@index([companyId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationDeliveryLog {
  id             String   @id @default(uuid())
  notificationId String?  @map("notification_id")
  companyId      String   @map("company_id")
  userId         String   @map("user_id")
  channel        String // EMAIL, WHATSAPP, SLACK, PUSH
  providerInfo   Json?    @map("provider_info") // Metadata de respuesta del API (Ej: id de resend, status)
  status         String   @default("SENT") // SENT, DELIVERED, FAILED
  errorMessage   String?  @map("error_message") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
  @@index([channel, status])
  @@map("notification_delivery_logs")
}

model WebhookEvent {
  id          String    @id @default(uuid())
  externalId  String    @unique @map("external_id")
  eventType   String    @map("event_type")
  platform   String    // META, TIKTOK, LINKEDIN, WHATSAPP
  payload    Json?
  processedAt DateTime  @default(now()) @map("processed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([platform])
  @@index([eventType])
  @@map("webhook_events")
}
