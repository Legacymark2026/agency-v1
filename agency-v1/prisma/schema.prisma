  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([category])
  @@map("email_templates")
}

model LeadScoringRule {
  id        String   @id @default(uuid())
  name      String
  field     String
  operator  String
  value     String?
  points    Int
  active    Boolean  @default(true)
  companyId String   @map("company_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([active])
  @@map("lead_scoring_rules")
}

model Campaign {
  id              String           @id @default(uuid())
  name            String
  code            String           @unique
  platform        String
  status          String           @default("ACTIVE")
  budget          Float?
  startDate       DateTime?        @map("start_date")
  endDate         DateTime?        @map("end_date")
  description     String?
  impressions     Int              @default(0)
  clicks          Int              @default(0)
  conversions     Int              @default(0)
  spend           Float            @default(0)
  companyId       String           @map("company_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  approvalStatus  String           @default("DRAFT") @map("approval_status")
  approvedById    String?          @map("approved_by_id")
  launchStatus    String           @default("PENDING") @map("launch_status")
  launchedAt      DateTime?        @map("launched_at")
  parameters      Json?
  trackingConfig  Json?            @map("tracking_config")
  adSpends        AdSpend[]
  assets          CampaignAsset[]
  rules           CampaignRule[]
  abTests         ABTest[]
  approvedBy      User?            @relation("ApprovedCampaigns", fields: [approvedById], references: [id])
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leads           Lead[]
  marketingEvents MarketingEvent[]

  @@index([companyId])
  @@index([code])
  @@index([status])
  @@map("campaigns")
}

model Lead {
  id       String  @id @default(uuid())
  name     String?
  email    String
  phone    String?
  company  String?
  jobTitle String? @map("job_title")
  message  String?
  source   String

  // Multi-channel Click IDs
  gclid     String? // Google Click ID
  fbclid    String? // Facebook Click ID
  li_fat_id String? // LinkedIn Click ID
  ttclid    String? // TikTok Click ID

  // Tracking Adicional (First-Party)
  fbp String? // Facebook Browser ID (First-party cookie)
  fbc String? // Facebook Click ID (First-party cookie)

  medium      String?
  utmSource   String? @map("utm_source")
  utmMedium   String? @map("utm_medium")
  utmCampaign String? @map("utm_campaign")
  utmTerm     String? @map("utm_term")
  utmContent  String? @map("utm_content")
  referer     String?
  landingPage String? @map("landing_page")
  ipAddress   String? @map("ip_address")
  userAgent   String? @map("user_agent")
  country     String?
  city        String?
  campaignId  String? @map("campaign_id")
  status      String  @default("NEW")
  score       Int     @default(0)

  // Machine Learning / Predictive Scoring
  conversionProbability Float? @map("conversion_probability")
  predictionFactors     Json?  @map("prediction_factors")

  convertedToDealId   String?            @map("converted_to_deal_id")
  convertedAt         DateTime?          @map("converted_at")
  formId              String?            @map("form_id")
  formData            Json?              @map("form_data")
  tags                String[]           @default([])
  notes               String?
  assignedTo          String?            @map("assigned_to")
  companyId           String             @map("company_id")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  conversations       Conversation[]
  eventParticipations EventParticipant[]
  campaign            Campaign?          @relation(fields: [campaignId], references: [id])
  crmCompany          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  marketingEvents     MarketingEvent[]
  invoices            Invoice[]

  @@unique([companyId, email])
  @@index([companyId])
  @@index([source])
  @@index([campaignId])
  @@index([createdAt])
  @@index([email])
  @@index([status])
  @@map("leads")
}

model MarketingEvent {
  id         String    @id @default(uuid())
  eventType  String
  eventName  String?
  url        String?
  referrer   String?
  userAgent  String?
  ipAddress  String?
  visitorId  String?   @map("visitor_id")
  leadId     String?   @map("lead_id")
  userId     String?   @map("user_id")
  properties Json?     @default("{}")
  sessionId  String?   @map("session_id")
  campaignId String?   @map("campaign_id")
  companyId  String    @map("company_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead?     @relation(fields: [leadId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([leadId])
  @@index([visitorId])
  @@index([eventType])
  @@index([createdAt])
  @@map("marketing_events")
}

model AdSpend {
  id          String    @id @default(uuid())
  date        DateTime  @db.Date
  platform    String
  amount      Float
  currency    String    @default("USD")
  impressions Int       @default(0)
  clicks      Int       @default(0)
  conversions Int       @default(0)
  revenue     Float     @default(0)
  ctr         Float     @default(0)
  cpc         Float     @default(0)
  roas        Float     @default(0)
  cpm         Float     @default(0)
  campaignId  String?   @map("campaign_id")
  companyId   String    @map("company_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  campaign    Campaign? @relation(fields: [campaignId], references: [id])
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([date, campaignId, platform])
  @@index([companyId])
  @@index([date])
  @@map("ad_spend")
}

model CampaignRule {
  id            String    @id @default(uuid())
  campaignId    String    @map("campaign_id")
  companyId     String    @map("company_id")
  name          String
  conditionKey  String    @map("condition_key") // e.g: "CPA", "SPEND", "IMPRESSIONS", "ROAS"
  operator      String    // e.g: "GREATER_THAN", "LESS_THAN"
  threshold     Float
  actionType    String    @map("action_type") // e.g: "PAUSE", "NOTIFY", "INCREASE_BUDGET"
  actionValue   String?   @map("action_value") // Payload optional, e.g: notify email
  isActive      Boolean   @default(true) @map("is_active")
  lastTriggered DateTime? @map("last_triggered")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  campaign      Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([campaignId])
  @@index([isActive])
  @@map("campaign_rules")
}

model CampaignAsset {
  id              String                @id @default(uuid())
  campaignId      String?               @map("campaign_id")
  companyId       String                @map("company_id")
  url             String
  type            String // IMAGE | VIDEO | COPY
  width           Int?
  height          Int?
  sizeBytes       Int?                  @map("size_bytes")
  duration        Int? // seconds for video
  altText         String?               @map("alt_text")
  mimeType        String?               @map("mime_type")
  name            String?
  createdAt       DateTime              @default(now()) @map("created_at")
  campaign        Campaign?             @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  company         Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  abVariants      ABTestVariant[]
  annotations     AssetAnnotation[]
  versions        AssetVersion[]
  collectionItems AssetCollectionItem[]

  @@index([companyId])
  @@index([campaignId])
  @@map("campaign_assets")
}

model ABTest {
  id         String          @id @default(uuid())
  campaignId String          @map("campaign_id")
  companyId  String          @map("company_id")
  name       String
  metric     String // CTR | ROAS | CPC
  status     String          @default("RUNNING") // RUNNING | COMPLETED | PAUSED
  winnerId   String?         @map("winner_id")
  startDate  DateTime        @map("start_date")
  endDate    DateTime?       @map("end_date")
  createdAt  DateTime        @default(now()) @map("created_at")
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  variants   ABTestVariant[]

  @@index([campaignId])
  @@index([companyId])
  @@map("ab_tests")
}

model ABTestVariant {
  id          String         @id @default(uuid())
  abTestId    String         @map("ab_test_id")
  assetId     String?        @map("asset_id")
  name        String
  weight      Float          @default(0.5) // 0..1
  impressions Int            @default(0)
  clicks      Int            @default(0)
  conversions Int            @default(0)
  spend       Float          @default(0)
