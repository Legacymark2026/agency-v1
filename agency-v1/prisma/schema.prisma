  subtotalAmount Float @default(0) @map("subtotal_amount")
  taxAmount      Float @default(0) @map("tax_amount")
  discountAmount Float @default(0) @map("discount_amount")
  totalAmount    Float @map("total_amount")
  advanceAmount  Float @map("advance_amount") // 60%
  finalAmount    Float @map("final_amount") // 40%

  status    String    @default("DRAFT_AWAITING_PAYMENT") // DRAFT, PAID, CANCELLED, SENT
  dueDate   DateTime? @map("due_date")
  notes     String?   @db.Text
  terms     String?   @db.Text
  companyId String    @map("company_id")
  leadId    String?   @map("lead_id")
  dealId    String?   @map("deal_id")

  stripeInvoiceId String? @map("stripe_invoice_id")
  paymentUrl      String? @map("payment_url")
  pdfUrl          String? @map("pdf_url")
  token           String? @unique @default(uuid())
  currency        String  @default("USD")

  isElectronic Boolean @default(true) @map("is_electronic")
  dianStatus   String? @map("dian_status") // PENDING, SENT, ACCEPTED, REJECTED
  cufe         String?
  qrCode       String? @map("qr_code") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company      Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead         Lead?                  @relation(fields: [leadId], references: [id])
  deal         Deal?                  @relation(fields: [dealId], references: [id])
