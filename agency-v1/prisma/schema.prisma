}

model ReadingListItem {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  postSlug String   @map("post_slug")
  addedAt  DateTime @default(now()) @map("added_at")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postSlug])
  @@index([userId])
  @@map("reading_list_items")
}

model Deal {
  id                  String                    @id @default(uuid())
  title               String
  value               Float                     @default(0)
  currency            String                    @default("USD")
  stage               String                    @default("NEW")
  probability         Int                       @default(0)
  contactName         String?                   @map("contact_name")
  contactEmail        String?                   @map("contact_email")
  companyId           String                    @map("company_id")
  priority            String                    @default("MEDIUM")
  notes               String?
  lostReason          String?                   @map("lost_reason")
  lastActivity        DateTime                  @default(now()) @map("last_activity")
  tags                String[]                  @default([])
  source              String?                   @default("Unknown")
  expectedClose       DateTime?                 @map("expected_close")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  assignedTo          String?                   @map("assigned_to")
  kanbanTaskId        String?                   @unique @map("kanban_task_id")
  activities          CRMActivity[]
  stageHistory        DealStageHistory[]
  commissions         CommissionPayment[]
  sequenceEnrollments EmailSequenceEnrollment[]
  assignedUser        User?                     @relation("AssignedDeals", fields: [assignedTo], references: [id])
  kanbanTask          KanbanTask?               @relation(fields: [kanbanTaskId], references: [id])
  company             Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events              Event[]
  kanbanProject       KanbanProject?
  proposals           Proposal[]
  invoices            Invoice[]

  @@index([companyId])
  @@index([stage])
  @@index([priority])
  @@index([assignedTo])
  @@map("deals")
}

model CRMActivity {
  id        String   @id @default(uuid())
  type      String
  content   String
  dealId    String   @map("deal_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([dealId])
  @@index([userId])
  @@index([createdAt])
  @@map("crm_activities")
}

model DealStageHistory {
  id        String   @id @default(uuid())
  dealId    String   @map("deal_id")
  fromStage String   @map("from_stage")
  toStage   String   @map("to_stage")
  changedBy String?  @map("changed_by")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user      User?    @relation("StageHistoryUser", fields: [changedBy], references: [id])

  @@index([dealId])
  @@index([createdAt])
  @@map("deal_stage_history")
}

// ─── A: METAS DE VENTAS ────────────────────────────────────────────────────────
model SalesGoal {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  userId       String?  @map("user_id") // null = goal global de la empresa
  departmentId String?  @map("department_id")
  level        String   @default("INDIVIDUAL") // AGENCY, DEPARTMENT, TEAM, INDIVIDUAL
  period       String // Formato "YYYY-MM" ej: "2026-03"
  targetAmount Float    @map("target_amount")
  currency     String   @default("USD")
  label        String? // "Q1 2026", "Marzo 2026", etc.
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserSalesGoals", fields: [userId], references: [id])

  @@unique([companyId, userId, period])
  @@index([companyId])
  @@index([period])
  @@map("sales_goals")
}

// ─── E: COMISIONES ────────────────────────────────────────────────────────────
model CommissionRule {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  userId       String?  @map("user_id") // null = regla global
  rate         Float // % ej: 0.05 = 5%
  minDealValue Float    @default(0) @map("min_deal_value")
  capAmount    Float?   @map("cap_amount") // Comisión máxima por deal
  isActive     Boolean  @default(true) @map("is_active")
  label        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation("UserCommissionRules", fields: [userId], references: [id])

  @@index([companyId])
  @@map("commission_rules")
}

model CommissionPayment {
  id        String    @id @default(uuid())
  companyId String    @map("company_id")
  dealId    String    @map("deal_id")
  userId    String    @map("user_id") // rep que gana la comisión
  ruleId    String?   @map("rule_id")
  amount    Float
  rate      Float
  type      String    @default("STANDARD") // STANDARD, ACCELERATOR, CLAWBACK, LTV_BONUS
  status    String    @default("PENDING") // PENDING, APPROVED, PAID, CANCELLED
  paidAt    DateTime? @map("paid_at")
  notes     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user    User    @relation("UserCommissionPayments", fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([dealId])
  @@index([status])
  @@map("commission_payments")
}

// ─── C: AUTOMATION RULES ──────────────────────────────────────────────────────
model DealAutomationRule {
  id             String    @id @default(uuid())
  companyId      String    @map("company_id")
  name           String
  description    String?
  isActive       Boolean   @default(true) @map("is_active")
  // Trigger: STAGE_STUCK_X_DAYS | DEAL_CREATED | STAGE_CHANGED | WON | LOST
  triggerType    String    @map("trigger_type")
  triggerStage   String?   @map("trigger_stage") // Para STAGE_STUCK_X_DAYS
  triggerDays    Int?      @map("trigger_days") // Para STAGE_STUCK_X_DAYS
  // Action: NOTIFY_ASSIGNEE | NOTIFY_ADMIN | SEND_EMAIL | CHANGE_PRIORITY | MOVE_STAGE
  actionType     String    @map("action_type")
  actionPayload  Json      @map("action_payload") // { message, email, stage, priority }
  lastRunAt      DateTime? @map("last_run_at")
  executionCount Int       @default(0) @map("execution_count")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs    AutomationLog[]

  @@index([companyId])
  @@index([isActive])
  @@map("deal_automation_rules")
}

model AutomationLog {
  id        String   @id @default(uuid())
  ruleId    String   @map("rule_id")
  dealId    String?  @map("deal_id")
  result    String // SUCCESS | SKIPPED | ERROR
  message   String?
  createdAt DateTime @default(now()) @map("created_at")

  rule DealAutomationRule? @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("automation_logs")
}

// ─── G: EMAIL SEQUENCES ───────────────────────────────────────────────────────
model EmailSequence {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  name         String
  description  String?
  triggerStage String?  @map("trigger_stage") // Stage que activa la secuencia
  isActive     Boolean  @default(true) @map("is_active")
  // steps: [{delay_days, subject, body, type: EMAIL|TASK}]
  steps        Json     @default("[]")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company     Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  enrollments EmailSequenceEnrollment[]

  @@index([companyId])
  @@map("email_sequences")
}

model EmailSequenceEnrollment {
  id          String    @id @default(uuid())
  sequenceId  String    @map("sequence_id")
  dealId      String    @map("deal_id")
  currentStep Int       @default(0) @map("current_step")
  status      String    @default("ACTIVE") // ACTIVE | PAUSED | COMPLETED | CANCELLED
  nextRunAt   DateTime? @map("next_run_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  sequence EmailSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  deal     Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, dealId])
  @@index([sequenceId])
  @@index([dealId])
  @@index([status, nextRunAt])
  @@map("email_sequence_enrollments")
}

model Task {
