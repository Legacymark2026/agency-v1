generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_EXTERNAL_URL")
}

model User {
  id                      String                    @id @default(uuid())
  name                    String?
  email                   String?                   @unique
  emailVerified           DateTime?                 @map("email_verified")
  image                   String?
  passwordHash            String?                   @map("password_hash")
  firstName               String?                   @map("first_name")
  lastName                String?                   @map("last_name")
  phone                   String?
  role                    String                    @default("guest")
  globalRole              String                    @default("client_user") @map("global_role") // RBAC: rol global del sistema
  mfaEnabled              Boolean                   @default(false) @map("mfa_enabled")
  mfaSecret               String?                   @map("mfa_secret")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @updatedAt @map("updated_at")
  deactivatedAt           DateTime?                 @map("deactivated_at")
  adminNotes              String?                   @map("admin_notes")
  customTag               String?                   @map("custom_tag")
  jobTitle                String?                   @map("job_title")
  backupCodes             Json?                     @map("backup_codes")
  accounts                Account[]
  annotations             Annotation[]
  apiKeys                 ApiKey[]
  approvedCampaigns       Campaign[]                @relation("ApprovedCampaigns")
  invitedUsers            CompanyUser[]             @relation("InvitedBy")
  companies               CompanyUser[]
  assignedConversations   Conversation[]
  crmActivities           CRMActivity[]
  assignedDeals           Deal[]                    @relation("AssignedDeals")
  stageHistoryChanges     DealStageHistory[]        @relation("StageHistoryUser")
  salesGoals              SalesGoal[]               @relation("UserSalesGoals")
  commissionRules         CommissionRule[]          @relation("UserCommissionRules")
  commissionPayments      CommissionPayment[]       @relation("UserCommissionPayments")
  eventParticipations     EventParticipant[]
  organizedEvents         Event[]                   @relation("EventOrganizer")
  agentConversations      AgentConversation[]
  marketingEvents         MarketingEvent[]
  posts                   Post[]
  readingList             ReadingListItem[]
  sessions                Session[]
  assignedTasks           Task[]                    @relation("TaskAssignee")
  createdTasks            Task[]                    @relation("TaskCreator")
  assignedKanbanTasks     KanbanTask[]              @relation("KanbanTaskAssignee")
  createdKanbanTasks      KanbanTask[]              @relation("KanbanTaskCreator")
  timeEntries             TimeEntry[]
  proposals               Proposal[]
  activityLogs            UserActivityLog[]
  profile                 UserProfile?
  createdBounties         Bounty[]                  @relation("BountyCreator")
  claimedBounties         Bounty[]                  @relation("BountyClaimer")
  socialPosts             SocialPost[]              @relation("SocialPostAuthor")
  approvedSocialPosts     SocialPost[]              @relation("SocialPostApprover")
  socialPostComments      SocialPostComment[]
  socialPostLogs          SocialPostLog[]
  approvedTimesheets      Timesheet[]               @relation("TimesheetApprover")
  approvedTimeOffs        TimeOffRequest[]          @relation("TimeOffApprover")
  assetAnnotations        AssetAnnotation[]
  assetVersions           AssetVersion[]
  assetCollections        AssetCollection[]
  createdExpenses         Expense[]                 @relation("ExpenseCreator")
  approvedExpenses        Expense[]                 @relation("ExpenseApprover")
  payrollAuditLogs        PayrollAuditLog[]         @relation("PayrollAuditor")
  kanbanComments          KanbanComment[]           @relation("KanbanCommentAuthor")
  kanbanSubtasks          KanbanSubtask[]           @relation("KanbanSubtaskCreator")
  kanbanAuditLogs         KanbanAuditLog[]          @relation("KanbanAuditActor")
  kanbanAnnotations       KanbanAssetAnnotation[]   @relation("AnnotationAuthor")
  Notification            Notification[]
  NotificationDeliveryLog NotificationDeliveryLog[]
  
  // RBAC relations
  resourcePermissions ResourcePermission[]

  @@index([role])
  @@index([email])
  @@map("users")
}

// ── Permisos de roles custom ───────────────────────────────
// Cada entrada define las rutas accesibles para un rol personalizado.
// Administrado por SUPER_ADMIN desde la UI de gestión de roles.
model RoleConfig {
  id            String   @id @default(uuid())
  roleName      String   @unique @map("role_name")
  allowedRoutes Json     @default("[]") @map("allowed_routes")
  description   String?
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([roleName])
  @@map("role_configs")
}

// ── RBAC: Catálogo de permisos del sistema ───────────────────────────────
model Permission {
  id          String   @id @default(uuid())
  name        String   @unique // ej: "crm.leads.create"
  module      String   // ej: "crm", "marketing", "content"
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  
  rolePermissions RolePermission[]
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@index([module])
  @@map("permissions")
}

// ── RBAC: Roles personalizados por empresa ───────────────────────────────
model Role {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  name        String   // ej: "Admin Ventas", "Marketing Manager"
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0) // para ordenamiento (mayor = más permisos)
  
  permissions  RolePermission[]
  users        CompanyUser[]
  
  company      Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  @@unique([companyId, name])
  @@index([companyId])
  @@map("roles")
}

// ── RBAC: Relación rol - permiso ─────────────────────────────────────────
model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime  @default(now()) @map("created_at")
  
  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ── RBAC: Permisos granulares por recurso específico (override) ───────────
model ResourcePermission {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  companyId    String   @map("company_id")
  resourceType String   // ej: "project", "deal", "campaign"
  resourceId   String   @map("resource_id")
  permission   String   // nombre del permiso (ej: "crm.deals.edit")
  access       Boolean  @default(true) // true = permitir, false = denegar
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  @@unique([userId, companyId, resourceType, resourceId, permission])
  @@index([userId, companyId])
  @@index([resourceType, resourceId])
  @@map("resource_permissions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

model UserProfile {
  id               String  @id @default(uuid())
  userId           String  @unique @map("user_id")
  jobTitle         String? @map("job_title")
  department       String?
  bio              String?
  socialLinks      Json?   @default("{}") @map("social_links")
  preferences      Json?   @default("{\"theme\": \"system\", \"notifications\": {\"email\": true}}")
  metadata         Json?   @default("{}")
  googleAnalytics  Json?   @map("google_analytics_config")
  facebookPixel    Json?   @map("facebook_pixel_config")
  googleTagManager Json?   @map("google_tag_manager_config")
  hotjar           Json?   @map("hotjar_config")
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Company {
  id                      String                    @id @default(uuid())
  name                    String
  slug                    String                    @unique
  logoUrl                 String?                   @map("logo_url")
  industry                String?
  website                 String?
  subscriptionTier        String                    @default("free") @map("subscription_tier")
  subscriptionStatus      String                    @default("active") @map("subscription_status")
  stripeCustomerId        String?                   @map("stripe_customer_id")
  stripeSubscriptionId    String?                   @map("stripe_subscription_id")
  createdAt               DateTime                  @default(now()) @map("created_at")
  defaultCompanySettings  Json?                     @map("default_settings")
  passwordPolicy          Json?                     @map("password_policy")
  whiteLabeling           Json?                     @map("white_labeling")
  brandKit                BrandKit?
  customObjectDefinitions CustomObjectDefinition[]
  adSpends                AdSpend[]
  apiKeys                 ApiKey[]
  campaigns               Campaign[]
  campaignAssets          CampaignAsset[]
  abTests                 ABTest[]
  members                 CompanyUser[]
  conversations           Conversation[]
  deals                   Deal[]
  emailTemplates          EmailTemplate[]
  events                  Event[]
  experiments             Experiment[]
  integrationConfigs      IntegrationConfig[]
  scoringRules            LeadScoringRule[]
  leads                   Lead[]
  marketingEvents         MarketingEvent[]
  shortLinks              ShortLink[]
  tasks                   Task[]
  teams                   Team[]
  workflows               Workflow[]
  socialPosts             SocialPost[]
  invoices                Invoice[]
  agentConversations      AgentConversation[]
  agentConfig             AgentConfig?
  aiAgents                AIAgent[]
  knowledgeBases          KnowledgeBase[]
  kanbanProjects          KanbanProject[]
  assetCollections        AssetCollection[]
  proposals               Proposal[]
  inboxMacros             InboxMacro[]
  employees               Employee[]
  payrolls                Payroll[]
  financialAccounts       FinancialAccount[]
  expenses                Expense[]
  employeeBenefits        EmployeeBenefit[]
  expenseCategories       ExpenseCategory[]
  webhooks                Webhook[]
  notificationPrefs       NotificationPreference[]
  usageLogs               UsageLog[]
  integrationLogs         IntegrationLog[]
  salesGoals              SalesGoal[]
  commissionRules         CommissionRule[]
  commissionPayments      CommissionPayment[]
  automationRules         DealAutomationRule[]
  emailSequences          EmailSequence[]
  campaignRules           CampaignRule[]
  servicePrices           ServicePrice[]
  Notification            Notification[]
  NotificationDeliveryLog NotificationDeliveryLog[]
  
  // RBAC relations
  roles                Role[]
  resourcePermissions ResourcePermission[]

  @@map("companies")
}

model ServicePrice {
  id              String   @id @default(uuid())
  companyId       String   @map("company_id")
  codigo_id       String?  @map("codigo_id")
  nombre_servicio String
  categoria       String
  tipo_formato    String?  @map("tipo_formato")
  tiempo_estimado String?  @map("tiempo_estimado")
  herramientas    String?  @db.Text
  descripcion     String   @db.Text
  
  // Tax & Financials
  precio_base     Float
  iva_porcentaje  Float    @default(19.0)
  iva_valor       Float?   @default(0) @map("iva_valor")
  retefuente_porc Float    @default(11.0)
  retefuente_valor Float?  @default(0) @map("retefuente_valor")
  reteiva_porc    Float    @default(2.85)
  reteiva_valor   Float?   @default(0) @map("reteiva_valor")
  ica_porc        Float    @default(0.6)
  ica_valor       Float?   @default(0) @map("ica_valor")
  subtotal        Float?   @default(0)

  precio_urgente  Float?
  isExpress       Boolean  @default(false)
  estado          String   @default("activo")
  orderIndex      Int      @default(0) @map("order_index")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("service_prices")
}

model BrandKit {
  id             String   @id @default(uuid())
  companyId      String   @unique @map("company_id")
  name           String   @default("Brand Kit")
  primaryColor   String   @default("#6D28D9") @map("primary_color")
  secondaryColor String   @default("#FFFFFF") @map("secondary_color")
  accentColor    String   @default("#10B981") @map("accent_color")
  logoUrl        String?  @map("logo_url")
  fontFamily     String   @default("Inter") @map("font_family")
  toneOfVoice    String   @default("professional") @map("tone_of_voice")
  brandValues    String[] @map("brand_values")
  targetAudience String?  @map("target_audience")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("brand_kits")
}

model CompanyUser {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  companyId      String   @map("company_id")
  roleName       String   @default("member") @map("role_name") // legacy role field
  permissions    Json?    @default("[]")
  invitedBy      String?  @map("invited_by")
  joinedAt       DateTime @default(now()) @map("joined_at")
  teamId         String?  @map("team_id")
  phoneExtension String?  @map("phone_extension")
  roleId         String?  @map("role_id") // RBAC: relación al rol personalizado
  
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inviter        User?    @relation("InvitedBy", fields: [invitedBy], references: [id])
  team           Team?    @relation(fields: [teamId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role?    @relation(fields: [roleId], references: [id])

  @@unique([userId, companyId])
  @@index([roleName])
  @@index([roleId])
  @@map("company_users")
}

model Team {
  id            String                   @id @default(uuid())
  name          String
  description   String?
  path          String                   @default("/")
  level         Int                      @default(0)
  parentId      String?                  @map("parent_id")
  companyId     String                   @map("company_id")
  maxHeadcount  Int?                     @map("max_headcount")
  monthlyBudget Float?                   @map("monthly_budget")
  createdAt     DateTime                 @default(now()) @map("created_at")
  updatedAt     DateTime                 @updatedAt @map("updated_at")
  permissions   CustomObjectPermission[]
  members       CompanyUser[]
  bounties      Bounty[]
  company       Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent        Team?                    @relation("TeamHierarchy", fields: [parentId], references: [id])
  children      Team[]                   @relation("TeamHierarchy")

  @@index([companyId])
  @@index([path])
  @@map("teams")
}

model CustomObjectDefinition {
  id                String                     @id @default(cuid())
  name              String
  label             String
  description       String?
  companyId         String
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  company           Company                    @relation(fields: [companyId], references: [id])
  fields            CustomObjectField[]
  permissions       CustomObjectPermission[]
  relationshipsFrom CustomObjectRelationship[] @relation("RelationshipFrom")
  relationshipsTo   CustomObjectRelationship[] @relation("RelationshipTo")
  records           CustomObjectRecord[]

  @@unique([companyId, name])
}

model CustomObjectField {
  id           String                 @id @default(cuid())
  name         String
  label        String
  type         String
  required     Boolean                @default(false)
  options      String?
  definitionId String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
}

model CustomObjectRelationship {
  id        String                 @id @default(cuid())
  name      String
  type      String
  fromId    String
  toId      String
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  from      CustomObjectDefinition @relation("RelationshipFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to        CustomObjectDefinition @relation("RelationshipTo", fields: [toId], references: [id], onDelete: Cascade)
}

model CustomObjectPermission {
  id           String                 @id @default(cuid())
  teamId       String
  definitionId String
  canCreate    Boolean                @default(false)
  canRead      Boolean                @default(false)
  canUpdate    Boolean                @default(false)
  canDelete    Boolean                @default(false)
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  team         Team                   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, definitionId])
}

model CustomObjectRecord {
  id           String                 @id @default(uuid())
  definitionId String                 @map("definition_id")
  data         Json
  createdBy    String?                @map("created_by")
  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt @map("updated_at")
  definition   CustomObjectDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@map("custom_object_records")
}

model UserActivityLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  details   Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("user_activity_logs")
}

model ApiKey {
  id        String    @id @default(uuid())
  name      String
  keyHash   String    @unique @map("key_hash")
  prefix    String?   @map("prefix")
  scopes    String[]  @default([])
  userId    String?   @map("user_id")
  companyId String?   @map("company_id")
  isActive  Boolean   @default(true) @map("is_active")
  expiresAt DateTime? @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?   @map("created_by")
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model Post {
  id              String      @id @default(uuid())
  title           String
  slug            String      @unique
  excerpt         String?
  content         String
  coverImage      String?     @map("cover_image")
  imageAlt        String?     @map("image_alt")
  published       Boolean     @default(false)
  metaTitle       String?     @map("meta_title")
  metaDescription String?     @map("meta_description")
  canonicalUrl    String?     @map("canonical_url")
  focusKeyword    String?     @map("focus_keyword")
  status          String      @default("draft")
  scheduledDate   DateTime?   @map("scheduled_date")
  authorId        String      @map("author_id")
  seriesId        String?     @map("series_id")
  seriesOrder     Int?        @map("series_order")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  comments        Comment[]
  likes           PostLike[]
  views           PostView[]
  author          User        @relation(fields: [authorId], references: [id])
  series          PostSeries? @relation(fields: [seriesId], references: [id])
  categories      Category[]  @relation("CategoryToPost")
  tags            Tag[]       @relation("PostToTag")

  @@index([authorId])
  @@index([seriesId])
  @@map("posts")
}

model Project {
  id                  String                @id @default(uuid())
  title               String
  slug                String                @unique
  description         String
  content             String?
  client              String?
  coverImage          String?               @map("cover_image")
  imageAlt            String?               @map("image_alt")
  gallery             Json?                 @default("[]")
  published           Boolean               @default(false)
  metaTitle           String?               @map("meta_title")
  metaDescription     String?               @map("meta_description")
  focusKeyword        String?               @map("focus_keyword")
  status              String                @default("draft")
  scheduledDate       DateTime?             @map("scheduled_date")
  featured            Boolean               @default(false)
  displayOrder        Int                   @default(0) @map("display_order")
  startDate           DateTime?             @map("start_date")
  endDate             DateTime?             @map("end_date")
  testimonial         String?
  results             Json?                 @default("[]")
  projectUrl          String?               @map("project_url")
  categoryId          String?               @map("category_id")
  createdAt           DateTime              @default(now()) @map("created_at")
  updatedAt           DateTime              @updatedAt @map("updated_at")
  clientLogo          String?               @map("client_logo")
  pdfUrl              String?               @map("pdf_url")
  private             Boolean               @default(false)
  seoScore            Int                   @default(0)
  team                Json?                 @default("[]")
  techStack           Json?                 @default("[]")
  videoUrl            String?               @map("video_url")
  ProjectToProjectTag ProjectToProjectTag[]
  views               ProjectView[]
  category            ProjectCategory?      @relation(fields: [categoryId], references: [id])
  services            Service[]             @relation("ProjectToService")

  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@map("projects")
}

model ProjectCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  color       String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  projects    Project[]

  @@map("project_categories")
}

model ProjectTag {
  id                  String                @id @default(uuid())
  name                String                @unique
  ProjectToProjectTag ProjectToProjectTag[]

  @@map("project_tags")
}

model ProjectView {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  ipHash    String   @map("ip_hash")
  userAgent String?  @map("user_agent")
  referer   String?
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, ipHash, createdAt])
  @@index([projectId])
  @@index([createdAt])
  @@map("project_views")
}

model Service {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  icon        String?
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  projects    Project[] @relation("ProjectToService")

  @@map("services")
}

model Tag {
  id    String @id @default(uuid())
  name  String @unique
  posts Post[] @relation("PostToTag")

  @@map("tags")
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("CategoryToPost")

  @@map("categories")
}

model Workflow {
  id            String              @id @default(uuid())
  name          String
  description   String?
  isActive      Boolean             @default(false) @map("is_active")
  triggerType   String              @map("trigger_type")
  triggerConfig Json                @map("trigger_config")
  steps         Json
  companyId     String              @map("company_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  executions    WorkflowExecution[]
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("workflows")
}

model WorkflowExecution {
  id          String    @id @default(uuid())
  status      String
  logs        Json?
  workflowId  String    @map("workflow_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  currentStep Int       @default(0) @map("current_step")
  resumeAt    DateTime? @map("resume_at")
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([status])
