model EmailBlast {
  id              String @id @default(uuid())
  name            String
  subject         String
  htmlBody        String @map("html_body")
  fromName        String @default("LegacyMark") @map("from_name")
  fromEmail       String @default("noreply@legacymarksas.com") @map("from_email")
  status          String @default("DRAFT") // DRAFT, QUEUED, SENDING, COMPLETED, FAILED
  totalRecipients Int    @default(0) @map("total_recipients")
  sent            Int    @default(0)
  failed          Int    @default(0)
  companyId       String @map("company_id")
  createdById     String @map("created_by_id")

  // Novedades: Scheduling y Drag&Drop Builder
  scheduledAt DateTime? @map("scheduled_at")
  designJson  Json?     @map("design_json")

  // Novedades: Pruebas A/B
  isAbTest  Boolean @default(false) @map("is_ab_test")
  subjectB  String? @map("subject_b")
  htmlBodyB String? @map("html_body_b")

  sentAt     DateTime?             @map("sent_at")
  createdAt  DateTime              @default(now()) @map("created_at")
  updatedAt  DateTime              @updatedAt @map("updated_at")
  recipients EmailBlastRecipient[]

  @@index([companyId])
  @@index([status])
  @@index([scheduledAt])
  @@map("email_blasts")
}

model EmailBlastRecipient {
  id           String  @id @default(uuid())
  blastId      String  @map("blast_id")
