<IfModule mod_headers.c>
    Header set Content-Security-Policy "default-src 'self'; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; img-src 'self' data: https: blob:; connect-src 'self' https:; frame-ancestors 'self';"
</IfModule>

# Habilitar CORS para recursos externos
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>